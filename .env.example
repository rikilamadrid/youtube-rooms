# Copy to .env.local (already gitignored) and fill in your own values.
# Never commit real credentials.

# Google Cloud Console OAuth 2.0 Client ID ("Web application" type),
# used by src/services/youtubeAuth.ts via Google Identity Services.
# Read-only YouTube scope only: https://www.googleapis.com/auth/youtube.readonly
VITE_GOOGLE_CLIENT_ID=
